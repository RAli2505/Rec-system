%%{init: {'theme': 'base', 'themeVariables': {
  'primaryColor': '#EBF0F5', 'primaryBorderColor': '#5B7BA0',
  'lineColor': '#2C3E50', 'textColor': '#2C3E50',
  'fontSize': '14px'
}}}%%

graph TD
    %% ── Input Layer ──────────────────────────────────
    DS["<b>Datasets</b><br/>EdNet KT2 (20K users, TOEIC)<br/>XES3G5M (6K users, Math)"]
    PP["<b>Data Preprocessing</b><br/>Feature Engineering + Confidence Synthesis"]
    SP["<b>User-Level Split</b><br/>70% Train / 15% Val / 15% Test"]

    DS --> PP --> SP

    %% ── Orchestrator ────────────────────────────────
    subgraph ORCH ["<b>ORCHESTRATOR</b>"]
        direction TB

        subgraph PIPES [" "]
            direction LR
            P1["🧊 Cold-Start<br/>Pipeline"]
            P2["📋 Assessment<br/>Pipeline"]
            P3["🔄 Continuous<br/>Pipeline"]
        end

        subgraph ROW1 [" "]
            direction LR
            DIAG["<b>DiagnosticAgent</b><br/><i>IRT 3PL + CAT</i><br/>θ ability estimation"]
            CONF["<b>ConfidenceAgent</b><br/><i>Rule-based 6-class</i><br/>behavioral confidence"]
        end

        subgraph ROW2 [" "]
            direction LR
            KG["<b>KnowledgeGraphAgent</b><br/><i>GraphSAGE embeddings</i><br/>+ Prerequisite mining"]
            PRED["<b>PredictionAgent</b><br/><i>SAINT Transformer 4L/256d</i><br/>→ 293-dim gap vector"]
        end

        REC["<b>RecommendationAgent</b><br/><i>Thompson Sampling + Weighted Linear</i><br/>6 features + MMR diversity"]
        PERS["<b>PersonalizationAgent</b><br/><i>IRT rule-based 5-level</i><br/>learner stratification"]

        %% ── Data flow arrows ──
        DIAG -->|"θ (ability)"| KG
        DIAG -->|"θ"| REC
        CONF -->|"confidence_class"| PRED
        CONF -->|"conf_class"| REC
        KG -->|"gap_tags, prereq_map<br/>mastered_tags"| REC
        PRED -->|"gap_probs[293]"| REC
        REC -->|"ranked items"| PERS
    end

    SP --> ORCH

    %% ── Output Layer ────────────────────────────────
    OUT["<b>Personalized Recommendation List</b><br/>Top-K ranked items with explanations"]
    PERS --> OUT

    %% ── Styles ──────────────────────────────────────
    classDef inputBox fill:#AED6F1,stroke:#5DADE2,stroke-width:2px,color:#2C3E50
    classDef outputBox fill:#A9DFBF,stroke:#27AE60,stroke-width:2px,color:#2C3E50
    classDef agentBox fill:#EBF0F5,stroke:#5B7BA0,stroke-width:1.5px,color:#2C3E50
    classDef pipeCS fill:#D6EAF8,stroke:#5DADE2,stroke-width:1px
    classDef pipeAS fill:#D5F5E3,stroke:#27AE60,stroke-width:1px
    classDef pipeCT fill:#FDEBD0,stroke:#E67E22,stroke-width:1px
    classDef recBox fill:#E8DAEF,stroke:#8E44AD,stroke-width:1.5px,color:#2C3E50

    class DS,PP,SP inputBox
    class OUT outputBox
    class DIAG,CONF,KG,PRED,PERS agentBox
    class REC recBox
    class P1 pipeCS
    class P2 pipeAS
    class P3 pipeCT
